# --- Core ---
ENVIRONMENT=development
DEBUG=true
SQL_ECHO=false

# --- Database ---
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/smartcart

# --- JWT ---
# MUST be 32+ characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace_me_with_a_real_32plus_character_secret_value
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# JSON array. Vite default is :5173
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# --- ML ---
DRL_INFERENCE_ENABLED=true
DRL_TRAINING_TRIGGER_THRESHOLD=20
DRL_ACTIVE_MODEL_REFRESH_SECONDS=60

# --- Bcrypt ---
BCRYPT_ROUNDS=12